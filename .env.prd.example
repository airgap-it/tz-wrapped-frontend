# Copy to .env on the deploy server (papers-ov-6.papers.tech:/home/papers/tz-wrapped-frontend/.env).
# CI overwrites IMAGE_TAG on each deploy; the rest you set once.

# GitLab container registry repo = $CI_REGISTRY_IMAGE (NO image name appended;
# compose adds /tz-wrapped-frontend). + tag (CI sed's IMAGE_TAG on deploy).
IMAGE_REGISTRY=registry.gitlab.papers.tech/papers/customer-tezos-foundation/tz-wrapped/dapp-frontend
IMAGE_TAG=latest

# Host port the nginx container is published on. The external reverse proxy
# routes tz-wrapped-frontend.prod.gke.papers.tech / foundry.wrappedtz.io here.
HOST_PORT=9004
